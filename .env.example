APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=sqlite:///./tunneldeck.db

ALLOWED_ADMIN_EMAILS=admin@example.com

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
# Alternative: set FIREBASE_CREDENTIALS_FILE instead of FIREBASE_* variables
# FIREBASE_CREDENTIALS_FILE=/absolute/path/to/firebase-service-account.json

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=

CLOUDFLARED_CONFIG_PATH=/etc/cloudflared/config.yml
CLOUDFLARED_SERVICE_NAME=cloudflared
CLOUDFLARED_BACKUP_DIR=./backups/cloudflared

DOCKER_SOCKET_PATH=/var/run/docker.sock

CORS_ALLOWED_ORIGINS=https://your-static-frontend-host.com
