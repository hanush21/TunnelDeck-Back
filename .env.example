APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=sqlite:///./tunneldeck.db
# For Docker/Coolify with persistent volume:
# DATABASE_URL=sqlite:////data/tunneldeck.db

ALLOWED_ADMIN_EMAILS=admin@example.com

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
# Alternative: set FIREBASE_CREDENTIALS_FILE instead of FIREBASE_* variables
# FIREBASE_CREDENTIALS_FILE=/absolute/path/to/firebase-service-account.json

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=

CLOUDFLARED_CONFIG_PATH=/etc/cloudflared/config.yml
# For Docker/Coolify shared volume with cloudflared:
# CLOUDFLARED_CONFIG_PATH=/data/cloudflared/config.yml
CLOUDFLARED_SERVICE_NAME=cloudflared
CLOUDFLARED_CONTROL_MODE=auto
CLOUDFLARED_DOCKER_CONTAINER_NAME=cloudflared
CLOUDFLARED_BACKUP_DIR=./backups/cloudflared
# For Docker/Coolify with persistent volume:
# CLOUDFLARED_BACKUP_DIR=/data/backups/cloudflared
CLOUDFLARED_BACKUP_MAX_FILES=20
TUNNEL_CONFIG_LOCK_PATH=./backups/cloudflared/config.lock
# For Docker/Coolify with persistent volume:
# TUNNEL_CONFIG_LOCK_PATH=/data/backups/cloudflared/config.lock
TUNNEL_CONFIG_LOCK_TIMEOUT_SECONDS=10

DOCKER_SOCKET_PATH=/var/run/docker.sock

CORS_ALLOWED_ORIGINS=https://your-static-frontend-host.com

RATE_LIMIT_TOTP_IP_MAX=5
RATE_LIMIT_TOTP_IP_WINDOW_SECONDS=60
RATE_LIMIT_TOTP_EMAIL_MAX=10
RATE_LIMIT_TOTP_EMAIL_WINDOW_SECONDS=300
